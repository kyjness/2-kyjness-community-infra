# PuppyTalk 인프라 - 환경 변수 예시
# 복사 후 .env 로 저장하고 값을 채운 뒤, 이 infra 폴더에서 docker compose 실행 시 사용합니다.
# DB·백엔드 관련 비밀번호 등은 백엔드 레포의 .env.production 과 맞춰야 합니다.

# MySQL (로컬/EC2 공통)
MYSQL_ROOT_PASSWORD=rootpassword
DB_NAME=puppytalk
DB_USER=root
DB_PASSWORD=rootpassword

# EC2용 docker-compose.ec2.yml 에서 추가로 사용
# CORS_ORIGINS=https://your-domain.com
