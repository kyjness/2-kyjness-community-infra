# 환경 변수 (비밀번호·시크릿 포함, 절대 커밋 금지)
.env
.env.*
!.env.example

# 로컬 Docker용 (docker-compose.local.yml). .env.*에 포함되나 경로 명시
.env.local

# 기타 로컬 전용 파일
*.local

# Terraform 변수 (db_master_password 등 — 커밋 금지)
terraform.tfvars
terraform.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# Terraform state/캐시/플랜 (커밋 금지)
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfplan
*.tfstate.backup
.terraform/
